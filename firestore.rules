rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthorized() {
      return request.auth != null &&
             (request.auth.token.email == "chinyihang06@gmail.com" ||
              request.auth.token.email == "shinyutoo@gmail.com");
    }

    function isOwner() {
      return resource.data.ownerEmail == request.auth.token.email;
    }

    match /events/{eventId} {
      allow read: if isAuthorized() &&
                     (resource.data.private != true || isOwner());
      allow create: if isAuthorized() &&
                       request.resource.data.ownerEmail == request.auth.token.email;
      // Both users may edit/delete shared events (together / anniversary).
      // Private and personal events remain owner-only.
      allow update, delete: if isAuthorized() &&
                               (isOwner() ||
                                resource.data.type == "together" ||
                                resource.data.type == "anniversary");
    }

    match /events/{eventId}/comments/{commentId} {
      allow read, write: if isAuthorized();
    }

    match /school_events/{eventId} {
      allow read, write: if isAuthorized();
    }

    match /users/{uid} {
      allow read: if isAuthorized();
      allow write: if isAuthorized() && request.auth.uid == uid;
    }

    match /couple/{doc} {
      // Public read of "shared" doc so maintenance flag works before login
      allow read: if doc == "shared" || isAuthorized();
      allow write: if isAuthorized();
    }

    match /pencil/{noteId} {
      allow read: if isAuthorized() &&
                     (resource.data.private != true || isOwner());
      allow write: if isAuthorized();
    }
  }
}
